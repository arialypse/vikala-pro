#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------
# ปรับเป็น production เมื่อใช้งานจริงบนเซิร์ฟเวอร์
CI_ENVIRONMENT = production

#--------------------------------------------------------------------
# APP SETTINGS
#--------------------------------------------------------------------
# URL หน้าแรกของเว็บไซต์ (อัปเดตตามโดเมนที่ระบุ โดยใช้ http ตามต้องการ)
app.baseURL = 'http://vikala.in.mg/'

# คีย์ความปลอดภัยสำหรับเข้ารหัสข้อมูลและ Session (แนะนำให้พิมพ์ข้อความสุ่มยาวๆ 32 ตัวอักษรขึ้นไปแทนที่ตรงนี้)
app.encryptionKey = 'เปลี่ยนเป็นคีย์ความปลอดภัยสุ่มยาวๆของคุณตรงนี้'

#--------------------------------------------------------------------
# DATABASE SETTINGS (MariaDB / MySQL)
#--------------------------------------------------------------------
# การตั้งค่าฐานข้อมูลเชื่อมต่อกับ phpMyAdmin บน cPanel ของโดเมน vikala.in.mg
database.default.hostname = localhost
database.default.database = ชื่อฐานข้อมูลที่สร้างบนcPanel
database.default.username = ชื่อผู้ใช้ฐานข้อมูลที่สร้างบนcPanel
database.default.password = รหัสผ่านฐานข้อมูลที่สร้างบนcPanel
database.default.DBDriver = MySQLi
database.default.DBPrefix = 
database.default.port     = 3306

# โครงสร้างภาษาไทยแบบพิเศษตามที่ออกแบบไว้ในสเปคฐานข้อมูล
database.default.charset  = utf8mb4
database.default.DBCollat = utf8mb4_unicode_520_ci

#--------------------------------------------------------------------
# SECURITY SETTINGS (CSRF & Session)
#--------------------------------------------------------------------
# เปิดใช้งานระบบป้องกันการยิงฟอร์มปลอม (CSRF) เพื่อความปลอดภัยสูงสุด
security.CSRFProtection = true
security.tokenName      = 'csrf_vikala_token'
security.cookieName     = 'csrf_vikala_cookie'
security.expires        = 7200
security.regenerate     = true
security.redirect       = false
